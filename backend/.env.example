# PostgreSQL: use the database name only (e.g. lifestyle_db), not "lifestyle_db.public"
# Schema "public" is used by default — do not put it in the URL.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/lifestyle_db"

PORT=5009
# Comma-separated origins for CORS (e.g. https://yourfrontend.com). If unset, localhost:5173 and :3000 are allowed.
# CORS_ORIGIN=https://yourfrontend.com,https://www.yourfrontend.com
MONGODB_URI=mongodb://localhost:27017/your_db
REDIS_URL=redis://localhost:6379

# Optional: set to 1 to store category image paths (e.g. categories/fashion.jpg) instead of full URLs.
# Use with VITE_MEDIA_BASE_URL in frontend so paths resolve. Supports both path and full URL in DB.
# SEED_MEDIA_AS_PATH=0

# ----- Auth (OTP + JWT + Google) -----
# JWT: use JWT_SECRET for access (15m) or JWT_ACCESS_SECRET + JWT_REFRESH_SECRET
JWT_SECRET=your_jwt_secret_min_32_chars
# JWT_ACCESS_SECRET=optional_if_using_JWT_SECRET
# JWT_REFRESH_SECRET=optional
# JWT_ACCESS_EXPIRATION=15m
# JWT_REFRESH_EXPIRATION=7d

# Brevo (transactional email for OTP)
# Use an API key from Settings → SMTP & API → API Keys (xkeysib-...), not SMTP key.
BREVO_API_KEY=your_brevo_api_key
# Sender must be verified in Brevo: Senders & IP → add sender → verify with 6-digit code. Else emails may not be delivered.
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Your Store

# Frontend URL (for OAuth redirect and links)
# Local: use your Vite dev server (e.g. 5173)
FRONTEND_URL=https://yourfrontend.com
# FRONTEND_URL=http://localhost:5173

# Google OAuth (optional)
# Works from local: in Google Cloud Console add Authorized redirect URI:
#   http://localhost:5001/api/v1/auth/google/callback
# (or API_BASE_URL below if your backend port is different)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Backend base URL for OAuth callback. Local: http://localhost:PORT (e.g. 5009)
# API_BASE_URL=http://localhost:5009
