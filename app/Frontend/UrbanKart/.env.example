# Backend API base URL (no trailing slash). When empty, the frontend uses the same origin.
# Example: run backend on port 5009 and frontend (Vite) on 5008, set:
# VITE_API_URL=http://localhost:5009

# Optional: base URL for uploaded media (Blob/S3/B2/CDN). Required for banners/videos stored as paths (e.g. products/uuid.mp4).
# Example Azure Blob: https://<account>.blob.core.windows.net/<container>
# VITE_MEDIA_BASE_URL=https://youraccount.blob.core.windows.net/yourcontainer
VITE_MEDIA_BASE_URL=https://f000.backblazeb2.com/file/Product2026
